# ── AIGO-X Azure Deployment Environment Variables ──────────────────────────────
# Copy to .env, fill in values, then source before running azure/deploy.sh
# DO NOT commit this file with real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Azure authentication ───────────────────────────────────────────────────────

# Option A: Service principal (CI/CD)
ARM_CLIENT_ID=00000000-0000-0000-0000-000000000000
ARM_CLIENT_SECRET=CHANGEME
ARM_TENANT_ID=00000000-0000-0000-0000-000000000000
ARM_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Option B: Azure CLI login (developer workstation)
# Run: az login

# ── Deployment config ─────────────────────────────────────────────────────────
DEPLOY_ENV=prod          # dev | staging | prod
IMAGE_TAG=1.0.0          # Docker image tag to deploy
AZURE_LOCATION=eastus    # Azure region

# ── Terraform variables ────────────────────────────────────────────────────────
TF_VAR_environment=prod
TF_VAR_location=eastus
TF_VAR_image_tag=1.0.0
TF_VAR_project_name=aigo-x

# AKS node sizing
TF_VAR_k8s_version=1.29
TF_VAR_system_node_vm_size=Standard_D4s_v3
TF_VAR_user_node_vm_size=Standard_D4s_v3
TF_VAR_user_node_min_count=2
TF_VAR_user_node_max_count=10

# PostgreSQL
TF_VAR_db_sku_name=GP_Standard_D2s_v3
TF_VAR_db_name=dufense_grc
TF_VAR_db_admin_login=grc_admin

# Redis
TF_VAR_redis_sku_name=Standard
TF_VAR_redis_capacity=1

# Domain (required for App Gateway TLS)
TF_VAR_domain_name=grc.example.com

# ── Secrets (set in Azure Key Vault after infra deploy) ────────────────────────
# Update secrets via Azure CLI:
#
#   az keyvault secret set --vault-name aigo-x-prod-kv \
#     --name jwt-secret --value "$(openssl rand -hex 32)"
#
#   az keyvault secret set --vault-name aigo-x-prod-kv \
#     --name openai-api-key --value "sk-..."
#
# Required after first deploy:
#   jwt-secret           — min 64 hex chars
#   db-password          — strong PostgreSQL password
#   redis-password       — Redis auth password
#   token-encryption-key — 32 char key
#   openai-api-key       — your OpenAI API key (AI features)

# ── For --helm-only mode ───────────────────────────────────────────────────────
# AZURE_ACR_NAME=aigoxprodacr
# AZURE_RESOURCE_GROUP=aigo-x-prod-rg
# AZURE_AKS_NAME=aigo-x-prod-aks
