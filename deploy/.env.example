# ═══════════════════════════════════════════════════════════════════════════════
# DuFense AIGO-X GRC Platform — Environment Configuration
# Copy this file to .env and fill in all CHANGE_ME values before deploying.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Deployment Mode ────────────────────────────────────────────────────────────
# DEPLOYMENT_TYPE: cloud | onprem
DEPLOYMENT_TYPE=onprem
# TENANT_MODE: single | multi
#   single — one organisation, dedicated instance, no tenant management UI
#   multi  — multiple organisations sharing one platform instance
TENANT_MODE=multi
APP_VERSION=1.0.0
NODE_ENV=production

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=grc_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_20_CHARS
POSTGRES_DB=dufense_grc
DATABASE_URL=postgresql://grc_user:CHANGE_ME_STRONG_PASSWORD_MIN_20_CHARS@postgres:5432/dufense_grc

# ── Security ───────────────────────────────────────────────────────────────────
# JWT_SECRET: minimum 64 random characters — generate with:
#   openssl rand -base64 64
JWT_SECRET=CHANGE_ME_AT_LEAST_64_RANDOM_CHARACTERS_USE_OPENSSL_RAND

# TOKEN_ENCRYPTION_KEY: exactly 32 hex characters — generate with:
#   openssl rand -hex 16
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_HEX_CHARS

# SESSION_SECRET: minimum 32 random characters
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ── AI Features ────────────────────────────────────────────────────────────────
# Leave blank to disable AI vCISO, report generation, and AI enrichment
OPENAI_API_KEY=

# ── Network ────────────────────────────────────────────────────────────────────
WEB_PORT=443
API_PORT=8080

# ── Single-Tenant Only ─────────────────────────────────────────────────────────
# (only used when TENANT_MODE=single)
ORG_NAME=My Organisation
ADMIN_EMAIL=admin@example.com

# ── Optional: SSO Integration ─────────────────────────────────────────────────
# SSO_ENABLED: true | false
SSO_ENABLED=false
# SAML_ENTRY_POINT=https://idp.example.com/sso/saml
# SAML_ISSUER=dufense-grc
# SAML_CERT=<base64 IDP certificate>

# ── Optional: Email Notifications ─────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=grc-notifications@example.com
# SMTP_PASS=CHANGE_ME
# SMTP_FROM="DuFense GRC <grc-notifications@example.com>"

# ── Optional: Audit Log Retention ─────────────────────────────────────────────
# AUDIT_RETENTION_DAYS=365
