# ── AIGO-X AWS Deployment Environment Variables ────────────────────────────────
# Copy to .env, fill in values, then source before running aws/deploy.sh
# DO NOT commit this file with real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS credentials (choose one method) ───────────────────────────────────────

# Option A: IAM user keys (not recommended for production; prefer IAM roles)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Option B: Named profile (SSO / assumed role)
# AWS_PROFILE=aigo-x-prod

# ── Deployment config ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
DEPLOY_ENV=prod         # dev | staging | prod
IMAGE_TAG=1.0.0         # Docker image tag to deploy

# ── Terraform variables (passed via TF_VAR_ prefix or -var flags) ─────────────
TF_VAR_aws_region=us-east-1
TF_VAR_environment=prod
TF_VAR_image_tag=1.0.0

# RDS
TF_VAR_db_instance_class=db.t3.medium
TF_VAR_db_name=dufense_grc
TF_VAR_db_username=grc_admin
TF_VAR_db_multi_az=true

# ElastiCache
TF_VAR_redis_node_type=cache.t3.small

# ALB / TLS (optional — leave empty to use HTTP only)
# TF_VAR_domain_name=grc.example.com
# TF_VAR_acm_certificate_arn=arn:aws:acm:us-east-1:123456789012:certificate/...

# ── Secrets (set via AWS Secrets Manager after infra deploy) ───────────────────
# Secrets are auto-generated by Terraform and stored in Secrets Manager.
# To override, update the secret values in Secrets Manager:
#
#   aws secretsmanager update-secret \
#     --secret-id aigo-x-prod/app-secrets \
#     --secret-string '{"JWT_SECRET":"...","OPENAI_API_KEY":"sk-..."}'
#
# Required overrides after first deploy:
#   OPENAI_API_KEY  — your OpenAI API key (optional; AI features disabled without it)
