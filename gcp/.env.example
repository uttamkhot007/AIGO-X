# ── AIGO-X GCP Deployment Environment Variables ────────────────────────────────
# Copy to .env, fill in values, then source before running gcp/deploy.sh
# DO NOT commit this file with real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── GCP authentication ─────────────────────────────────────────────────────────

# Option A: Service account key file (CI/CD)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option B: Application Default Credentials (developer workstation)
# Run: gcloud auth application-default login

# Option C: Workload Identity (GCP-hosted CI/CD)
# Configured automatically via Workload Identity Federation

# ── Required ───────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=my-gcp-project-id    # Your GCP project ID
GCP_REGION=us-central1              # Deployment region

# ── Deployment config ─────────────────────────────────────────────────────────
DEPLOY_ENV=prod     # dev | staging | prod
IMAGE_TAG=1.0.0     # Docker image tag to deploy

# ── Terraform variables ────────────────────────────────────────────────────────
TF_VAR_gcp_project_id=my-gcp-project-id
TF_VAR_gcp_region=us-central1
TF_VAR_environment=prod
TF_VAR_image_tag=1.0.0
TF_VAR_project_name=aigo-x

# GKE Autopilot
TF_VAR_gke_release_channel=REGULAR

# Cloud SQL
TF_VAR_db_tier=db-custom-2-7680
TF_VAR_db_name=dufense_grc
TF_VAR_db_user=grc_admin
TF_VAR_db_disk_size_gb=100
TF_VAR_db_backup_enabled=true
TF_VAR_db_deletion_protection=true

# Memorystore Redis
TF_VAR_redis_tier=STANDARD_HA
TF_VAR_redis_memory_size_gb=4

# Artifact Registry
TF_VAR_artifact_registry_location=us-central1

# Domain
TF_VAR_domain_name=grc.example.com

# ── Secrets (update in Secret Manager after infra deploy) ──────────────────────
# Update each secret:
#   echo -n 'MY_SECRET_VALUE' | \
#     gcloud secrets versions add aigo-x-prod-jwt-secret \
#     --data-file=- --project=my-gcp-project-id
#
# Secrets to update (all named aigo-x-<env>-<key>):
#   jwt-secret           — min 64 hex chars
#   db-password          — strong Cloud SQL password
#   redis-auth           — Redis AUTH token
#   token-encryption-key — 32 char key
#   openai-api-key       — your OpenAI API key (AI features)

# ── For --helm-only mode ───────────────────────────────────────────────────────
# GKE_CLUSTER_NAME=aigo-x-prod-gke
